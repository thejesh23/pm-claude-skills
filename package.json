    "build:deck": "node scripts/build-deck.mjs",
    "build:show": "node scripts/build-morning-show.mjs",
    "grow": "node scripts/mine-gaps.mjs",
    "build:modelbench": "node scripts/build-modelbench.mjs",
    "skill-of-the-week": "node scripts/skill-of-the-week.mjs",
    "check": "node scripts/skillcheck.mjs && node scripts/build-exports.mjs --check && node scripts/build-workflows.mjs --check && node web/build-skills.mjs && node scripts/build-samples.mjs && node scripts/build-skills-md.mjs && git diff --exit-code -- web/skills.json web/samples.json SKILLS.md",
    "improve": "node scripts/improve-skill.mjs",
    "eval:gen-cases": "node scripts/gen-eval-cases.mjs",
    "eval:all": "node scripts/gen-eval-cases.mjs && node evals/run-evals.mjs --cases evals/cases.full.json --models claude-haiku-4-5-20251001 --judge claude-haiku-4-5-20251001"
